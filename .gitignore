# ESPHome build cache (multiple GB)
.esphome/
build/
.pio/
.pioenvs/

# Local secrets — never committed. The distribution build does not
# require secrets, but if you fork and add a personal build, keep
# any secrets.yaml out of Git.
secrets.yaml
*.PRIVATE

# Python venv used by the local ESPHome toolchain
venv/
.venv/

# Editor & OS
.DS_Store
.idea/
.vscode/
*.swp
__pycache__/

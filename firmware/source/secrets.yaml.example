# =====================================================================
# secrets.yaml.example — copy this file and fill in unique values
# =====================================================================
# HOW TO USE
#
#   1. Copy this file:
#        cp secrets.yaml.example secrets.yaml
#
#   2. Generate a fresh API encryption key. Easiest way:
#        Open https://esphome.io/components/api in a browser.
#        The page has a key generator that runs locally in your
#        browser (nothing leaves your machine) and produces a 32-byte
#        base64 string. Click "Regenerate" once, then "Copy", and
#        paste it below as the value of `api_encryption_key`.
#
#   3. Pick strong, unique passwords for OTA and Web Server Auth.
#      Use a password manager — you will not need to type these often.
#      Recommendation: 20+ random characters, letters + digits +
#      symbols. Do NOT reuse the same passwords across devices.
#
#   4. Save the file. `secrets.yaml` is gitignored — it will NOT be
#      committed. Verify with `git status` after saving.
#
# WHY THIS MATTERS
#
#   The keys and passwords in this file are the ONLY thing standing
#   between someone on your local network and full control of the
#   device. If any of these values leak (screenshot, chat, screen
#   share, git commit), rotate them: change the value here, rebuild
#   the firmware (`esphome run …`), and re-add the device in Home
#   Assistant with the new API key.
#
# WHERE VALUES ARE REFERENCED
#
#   air-quality-monitor.yaml:
#     api.encryption.key   = !secret api_encryption_key
#     ota.password         = !secret ota_password
#     web_server.auth      = !secret web_username / web_password
#
# =====================================================================

# 32-byte base64 API encryption key (see step 2 above).
# The exact same value must be entered into Home Assistant when it
# prompts for the encryption key during device pairing.
api_encryption_key: "REPLACE_ME_WITH_A_FRESH_32_BYTE_BASE64_KEY_FROM_ESPHOME_DOCS"

# OTA firmware update password (see step 3 above).
# Required to push new firmware over Wi-Fi via `esphome run` or
# through the Home Assistant OTA update flow.
ota_password: "REPLACE_ME_WITH_A_LONG_RANDOM_PASSWORD"

# Web-UI basic-auth credentials (see step 3 above).
# Anyone opening http://<device-ip>/ in a browser must supply these.
web_username: "admin"
web_password: "REPLACE_ME_WITH_A_LONG_RANDOM_PASSWORD"
